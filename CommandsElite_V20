-- // INPUTS DE BASE // --
local function CreateBaseInput(name, pos, callback)
    local box = Instance.new("TextBox", Main)
    box.Size = UDim2.new(0.2, 0, 0, 45)
    box.Position = UDim2.new(0.02 + (pos * 0.21), 0, 0.88, 0)
    box.BackgroundColor3 = Theme.Secondary
    box.PlaceholderText = name
    box.Text = ""
    box.TextColor3 = Theme.Accent
    box.Font = Enum.Font.GothamBold
    Instance.new("UICorner", box)
    box.FocusLost:Connect(function() callback(tonumber(box.Text)) end)
end

