-- // PLAYER LIST // --
local function UpdatePlayers()
    for _, v in pairs(PlrScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(game.Players:GetPlayers()) do
        local b = Instance.new("TextButton", PlrScroll)
        b.Size = UDim2.new(1, -5, 0, 45)
        b.BackgroundColor3 = (Vars.Target == p) and Theme.Accent or Theme.Secondary
        b.Text = p.DisplayName:upper()
        b.TextColor3 = Theme.Text
        b.Font = Enum.Font.GothamBold
        b.TextSize = 16
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() Vars.Target = p UpdatePlayers() end)
    end
end

-- // LOOPS // --
RunService.Heartbeat:Connect(function()
    pcall(function()
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = Player.Character.HumanoidRootPart
            local hum = Player.Character.Humanoid
            
            if Vars.Fly or Vars.VFly then
                local target = hrp
                if Vars.VFly and hum.SeatPart and hum.SeatPart.Parent then
                    target = hum.SeatPart.Parent.PrimaryPart or hum.SeatPart
                end
                
                local cam = workspace.CurrentCamera.CFrame
                local vel = Vector3.new(0, 0.1, 0)
                if hum.MoveDirection.Magnitude > 0 then
                    vel = (cam:VectorToWorldSpace(Vector3.new(
                        UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or (UserInputService:IsKeyDown(Enum.KeyCode.A) and -1 or 0), 
                        0, 
                        UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or (UserInputService:IsKeyDown(Enum.KeyCode.W) and -1 or 0)
                    ))).Unit * 100
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0, 50, 0) end
                target.Velocity = vel
            end

            if Vars.AntiFall and hrp.Velocity.Y < -50 then
                hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
            end
            
            -- Mantém o estado enquanto o switch estiver ON
            if Vars.Ragdoll then hum.PlatformStand = true end

            if Vars.AutoWin then hrp.CFrame = CFrame.new(-108, 250, 32) hrp.Velocity = Vector3.new(0,0,0) end
            if Vars.Sticking and Vars.Target and Vars.Target.Character then hrp.CFrame = Vars.Target.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,4) end
        end
    end)
end)

RunService.Stepped:Connect(function()
    if Vars.Noclip and Player.Character then
        for _, v in pairs(Player.Character:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end
end)

UpdatePlayers()
game.Players.PlayerAdded:Connect(UpdatePlayers)
game.Players.PlayerRemoving:Connect(UpdatePlayers)
UserInputService.InputBegan:Connect(function(io, chat)
    if not chat and io.KeyCode == Enum.KeyCode.L then Main.Visible = not Main.Visible end
end)
