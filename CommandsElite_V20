local Pages = {}
local function CreateTab(name, id, pos)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0.2, 0, 0, 45)
    b.Position = UDim2.new(0.02 + (pos * 0.21), 0, 0.04, 0)
    b.BackgroundColor3 = Theme.Secondary
    b.Text = name
    b.TextColor3 = Theme.Text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 13
    Instance.new("UICorner", b)
    
    local p = Instance.new("ScrollingFrame", Main)
    p.Size = UDim2.new(0.65, -30, 1, -210)
    p.Position = UDim2.new(0, 20, 0, 95)
    p.BackgroundTransparency = 1
    p.Visible = (id == 1)
    p.ScrollBarThickness = 3
    Instance.new("UIListLayout", p).Padding = UDim.new(0, 8)
    Pages[id] = p
    
    b.MouseButton1Click:Connect(function()
        for _, pg in pairs(Pages) do pg.Visible = false end
        p.Visible = true
    end)
end

