-- ABA 2: MUNDO
AddSwitch("FPS Boost (Texturas)", Pages[2], function(v)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            if v then
                if not Memory.Materials[obj] then Memory.Materials[obj] = obj.Material end
                obj.Material = Enum.Material.SmoothPlastic
            else obj.Material = Memory.Materials[obj] or Enum.Material.Plastic end
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            if v then if not Memory.Decals[obj] then Memory.Decals[obj] = obj.Transparency end obj.Transparency = 1
            else obj.Transparency = Memory.Decals[obj] or 0 end
        end
    end
end)
AddSwitch("FullBright (Escuro)", Pages[2], function(v)
    Lighting.Brightness = v and 2 or Memory.Bright
    Lighting.ExposureCompensation = v and 3 or 0
    Lighting.GlobalShadows = not v
end)
AddSwitch("Remover Neblina", Pages[2], function(v)
    Lighting.FogEnd = v and 1e6 or Memory.Fog
    for _, atm in pairs(Lighting:GetChildren()) do
        if atm:IsA("Atmosphere") then
            if v then Memory.Atm[atm] = atm.Parent atm.Parent = nil
            else atm.Parent = Lighting end
        end
    end
end)
AddSwitch("Mudo Total", Pages[2], function(v)
    for _, s in pairs(game:GetDescendants()) do
        if s:IsA("Sound") then s.Volume = v and 0 or 0.5 end
    end
end)

