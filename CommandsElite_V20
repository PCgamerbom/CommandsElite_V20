-- // SWITCH ANIMADO // --
local function AddSwitch(name, parent, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, -10, 0, 50)
    f.BackgroundColor3 = Theme.Secondary
    Instance.new("UICorner", f)
    
    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(1, -70, 1, 0)
    t.Position = UDim2.new(0, 15, 0, 0)
    t.Text = name:upper()
    t.TextColor3 = Theme.Text
    t.Font = Enum.Font.GothamBold
    t.TextSize = 11
    t.TextXAlignment = Enum.TextXAlignment.Left
    t.BackgroundTransparency = 1
    
    local Sw = Instance.new("Frame", f)
    Sw.Size = UDim2.new(0, 42, 0, 22)
    Sw.Position = UDim2.new(1, -55, 0.5, -11)
    Sw.BackgroundColor3 = Theme.SwitchBg
    Instance.new("UICorner", Sw).CornerRadius = UDim.new(1, 0)
    
    local Dot = Instance.new("Frame", Sw)
    Dot.Size = UDim2.new(0, 18, 0, 18)
    Dot.Position = UDim2.new(0, 2, 0.5, -9)
    Dot.BackgroundColor3 = Theme.Red
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
    
    local active = false
    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    
    btn.MouseButton1Click:Connect(function()
        active = not active
        Dot:TweenPosition(active and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9), "Out", "Back", 0.3)
        Dot.BackgroundColor3 = active and Theme.Green or Theme.Red
        callback(active)
    end)
end

